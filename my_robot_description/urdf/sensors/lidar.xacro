<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="lidar">

  <!-- Lidar link: frame at the cylinder's geometric center -->
  <link name="lidar">
    <inertial>
      <mass value="${lidar_mass}"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia
          ixx="${lidar_mass * (3*lidar_radius**2 + lidar_height**2) / 12}"
          ixy="0"
          ixz="0"
          iyy="${lidar_mass * (3*lidar_radius**2 + lidar_height**2) / 12}"
          iyz="0"
          izz="${lidar_mass * lidar_radius**2 / 2}"/>
    </inertial>

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${lidar_radius}" length="${lidar_height}"/>
      </geometry>
      <material name="red">
        <color rgba="1.0 0.0 0.0 1.0"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${lidar_radius}" length="${lidar_height}"/>
      </geometry>
    </collision>
  </link>

  <!--
    Lidar joint: mount on top of chassis.
      z-offset = chassis_height/2 + lidar_height/2
        (lidar bottom flush with chassis top)
  -->
  <joint name="chassis_to_lidar_joint" type="fixed">
    <origin xyz="0 0 ${chassis_height/2 + lidar_height/2}" rpy="0 0 0"/>
    <parent link="chassis"/>
    <child link="lidar"/>
  </joint>


</robot>
