<?xml version="1.0" ?>
<sdf version="1.7">
  <model name="couch">
    <static>true</static>

    <!-- Seat cushion -->
    <link name="seat">
      <pose>0 0.15 0.225 0 0 0</pose>
      <collision name="collision">
        <geometry><box><size>2.20 0.60 0.45</size></box></geometry>
      </collision>
      <visual name="visual">
        <geometry><box><size>2.20 0.60 0.45</size></box></geometry>
        <material>
          <ambient>0.70 0.68 0.65 1</ambient>
          <diffuse>0.70 0.68 0.65 1</diffuse>
          <specular>0.03 0.03 0.03 1</specular>
        </material>
      </visual>
    </link>

    <!-- Backrest -->
