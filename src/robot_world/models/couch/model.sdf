      <pose>-1.025 0 0.35 0 0 0</pose>
      <collision name="collision">
        <geometry><box><size>0.15 0.90 0.70</size></box></geometry>
      </collision>
      <visual name="visual">
        <geometry><box><size>0.15 0.90 0.70</size></box></geometry>
        <material>
          <ambient>0.65 0.63 0.60 1</ambient>
          <diffuse>0.65 0.63 0.60 1</diffuse>
          <specular>0.03 0.03 0.03 1</specular>
        </material>
      </visual>
    </link>

    <!-- Right armrest -->
    <link name="armrest_right">
      <pose>1.025 0 0.35 0 0 0</pose>
      <collision name="collision">
        <geometry><box><size>0.15 0.90 0.70</size></box></geometry>
      </collision>
      <visual name="visual">
        <geometry><box><size>0.15 0.90 0.70</size></box></geometry>
